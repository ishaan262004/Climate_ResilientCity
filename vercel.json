{
  "version": 2,
  "installCommand": "npm install && npm install --prefix client",
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**",
      "memory": 512,
      "maxDuration": 30
    }
  }
}
